{
  "$schema": "playbook-v1",
  "id": "divergence_reversal",
  "name": "Divergence Reversal",
  "description": "Detect regular divergences between price and Kernel AO oscillator on H1. Confirm with H4 structure (approaching strong level), RSI Kernel extremes, NWE band test, and MACD 4C color change. Enter on M15 momentum shift.",
  "symbols": [
    "XAUUSD",
    "EURUSD",
    "GBPJPY"
  ],
  "autonomy": "signal_only",
  "indicators": [
    {
      "id": "h1_kernel_div",
      "name": "Kernel_Div",
      "timeframe": "H1"
    },
    {
      "id": "h1_rsi_kernel",
      "name": "RSI_Kernel",
      "timeframe": "H1"
    },
    {
      "id": "h1_nwe",
      "name": "NW_Envelope",
      "timeframe": "H1"
    },
    {
      "id": "h4_smc",
      "name": "SMC_Structure",
      "timeframe": "H4"
    },
    {
      "id": "h4_atr",
      "name": "ATR",
      "timeframe": "H4"
    },
    {
      "id": "m15_macd4c",
      "name": "MACD_4C",
      "timeframe": "M15"
    },
    {
      "id": "m15_stoch",
      "name": "Stochastic",
      "timeframe": "M15"
    },
    {
      "id": "m15_rsi",
      "name": "RSI",
      "timeframe": "M15"
    }
  ],
  "variables": {
    "direction": {
      "type": "string",
      "default": ""
    },
    "divergence_type": {
      "type": "string",
      "default": ""
    },
    "entry_price": {
      "type": "float",
      "default": 0.0
    },
    "initial_sl": {
      "type": "float",
      "default": 0.0
    },
    "tp1": {
      "type": "float",
      "default": 0.0
    },
    "tp2": {
      "type": "float",
      "default": 0.0
    },
    "risk_r": {
      "type": "float",
      "default": 0.0
    },
    "partial_closed": {
      "type": "bool",
      "default": false
    },
    "be_moved": {
      "type": "bool",
      "default": false
    }
  },
  "initial_phase": "idle",
  "phases": {
    "idle": {
      "description": "Wait for H1 Kernel AO bullish or bearish regular divergence.",
      "evaluate_on": [
        "H1"
      ],
      "transitions": [
        {
          "to": "confirm",
          "priority": 1,
          "conditions": {
            "type": "AND",
            "rules": [
              {
                "left": "ind.h1_kernel_div.bull_reg_div",
                "operator": "==",
                "right": "1",
                "description": "H1 Kernel AO bullish regular divergence detected"
              },
              {
                "left": "_price",
                "operator": "<=",
                "right": "ind.h4_smc.strong_low + ind.h4_atr.value * 1.0",
                "description": "Price near H4 strong low / support zone"
              }
            ]
          },
          "actions": [
            {
              "set_var": "direction",
              "expr": "'BUY'"
            },
            {
              "set_var": "divergence_type",
              "expr": "'bull_reg'"
            },
            {
              "log": "Bullish regular divergence detected near H4 strong low"
            }
          ]
        },
        {
          "to": "confirm",
          "priority": 0,
          "conditions": {
            "type": "AND",
            "rules": [
              {
                "left": "ind.h1_kernel_div.bear_reg_div",
                "operator": "==",
                "right": "1",
                "description": "H1 Kernel AO bearish regular divergence detected"
              },
              {
                "left": "_price",
                "operator": ">=",
                "right": "ind.h4_smc.strong_high - ind.h4_atr.value * 1.0",
                "description": "Price near H4 strong high / resistance zone"
              }
            ]
          },
          "actions": [
            {
              "set_var": "direction",
              "expr": "'SELL'"
            },
            {
              "set_var": "divergence_type",
              "expr": "'bear_reg'"
            },
            {
              "log": "Bearish regular divergence detected near H4 strong high"
            }
          ]
        }
      ],
      "timeout": null,
      "position_management": []
    },
    "confirm": {
      "description": "Confirm divergence with RSI extreme, NWE band test, and MACD 4C color change on M15.",
      "evaluate_on": [
        "M15"
      ],
      "transitions": [
        {
          "to": "entry",
          "priority": 1,
          "conditions": {
            "type": "AND",
            "rules": [
              {
                "left": "var.direction",
                "operator": "==",
                "right": "'BUY'",
                "description": "Long setup confirmation path"
              },
              {
                "left": "ind.h1_rsi_kernel.oversold",
                "operator": "==",
                "right": "1",
                "description": "H1 RSI Kernel in oversold zone"
              },
              {
                "left": "_price",
                "operator": "<=",
                "right": "ind.h1_nwe.lower_near",
                "description": "Price near H1 NW Envelope lower band"
              },
              {
                "left": "ind.m15_macd4c.color",
                "operator": "==",
                "right": "4",
                "description": "M15 MACD 4C color is red (4) \u00e2\u20ac\u201d momentum shifting"
              },
              {
                "left": "prev.m15_macd4c.color",
                "operator": "==",
                "right": "3",
                "description": "M15 MACD 4C previous color was maroon (3)"
              }
            ]
          },
          "actions": [
            {
              "log": "Long confirmation: RSI oversold + NWE lower band + MACD 4C maroon->red"
            }
          ]
        },
        {
          "to": "entry",
          "priority": 0,
          "conditions": {
            "type": "AND",
            "rules": [
              {
                "left": "var.direction",
                "operator": "==",
                "right": "'SELL'",
                "description": "Short setup confirmation path"
              },
              {
                "left": "ind.h1_rsi_kernel.overbought",
                "operator": "==",
                "right": "1",
                "description": "H1 RSI Kernel in overbought zone"
              },
              {
                "left": "_price",
                "operator": ">=",
                "right": "ind.h1_nwe.upper_near",
                "description": "Price near H1 NW Envelope upper band"
              },
              {
                "left": "ind.m15_macd4c.color",
                "operator": "==",
                "right": "1",
                "description": "M15 MACD 4C color is lime (1) \u00e2\u20ac\u201d momentum shifting"
              },
              {
                "left": "prev.m15_macd4c.color",
                "operator": "==",
                "right": "2",
                "description": "M15 MACD 4C previous color was green (2)"
              }
            ]
          },
          "actions": [
            {
              "log": "Short confirmation: RSI overbought + NWE upper band + MACD 4C green->lime"
            }
          ]
        }
      ],
      "timeout": {
        "bars": 12,
        "timeframe": "M15",
        "to": "idle"
      },
      "position_management": []
    },
    "entry": {
      "description": "Enter when M15 shows momentum shift via Stochastic cross.",
      "evaluate_on": [
        "M15"
      ],
      "transitions": [
        {
          "to": "in_position",
          "priority": 1,
          "conditions": {
            "type": "AND",
            "rules": [
              {
                "left": "var.direction",
                "operator": "==",
                "right": "'BUY'",
                "description": "Long entry path"
              },
              {
                "left": "ind.m15_stoch.k",
                "operator": ">",
                "right": "ind.m15_stoch.d",
                "description": "M15 Stochastic K crossed above D"
              },
              {
                "left": "prev.m15_stoch.k",
                "operator": "<=",
                "right": "prev.m15_stoch.d",
                "description": "M15 Stochastic K was below D on previous bar"
              },
              {
                "left": "ind.m15_stoch.k",
                "operator": "<",
                "right": "30",
                "description": "Stochastic cross happening from oversold zone"
              }
            ]
          },
          "actions": [
            {
              "set_var": "entry_price",
              "expr": "_price"
            },
            {
              "set_var": "initial_sl",
              "expr": "ind.h4_smc.strong_low - ind.h4_atr.value * 0.3"
            },
            {
              "set_var": "tp1",
              "expr": "ind.h1_nwe.yhat"
            },
            {
              "set_var": "tp2",
              "expr": "_price + (_price - (ind.h4_smc.strong_low - ind.h4_atr.value * 0.3)) * 2.0"
            },
            {
              "set_var": "risk_r",
              "expr": "_price - (ind.h4_smc.strong_low - ind.h4_atr.value * 0.3)"
            },
            {
              "open_trade": {
                "direction": "BUY",
                "sl": {
                  "expr": "ind.h4_smc.strong_low - ind.h4_atr.value * 0.3"
                },
                "tp": {
                  "expr": "ind.h1_nwe.yhat"
                }
              }
            },
            {
              "log": "Long entry: Stochastic K>D cross from oversold"
            }
          ]
        },
        {
          "to": "in_position",
          "priority": 0,
          "conditions": {
            "type": "AND",
            "rules": [
              {
                "left": "var.direction",
                "operator": "==",
                "right": "'SELL'",
                "description": "Short entry path"
              },
              {
                "left": "ind.m15_stoch.k",
                "operator": "<",
                "right": "ind.m15_stoch.d",
                "description": "M15 Stochastic K crossed below D"
              },
              {
                "left": "prev.m15_stoch.k",
                "operator": ">=",
                "right": "prev.m15_stoch.d",
                "description": "M15 Stochastic K was above D on previous bar"
              },
              {
                "left": "ind.m15_stoch.k",
                "operator": ">",
                "right": "70",
                "description": "Stochastic cross happening from overbought zone"
              }
            ]
          },
          "actions": [
            {
              "set_var": "entry_price",
              "expr": "_price"
            },
            {
              "set_var": "initial_sl",
              "expr": "ind.h4_smc.strong_high + ind.h4_atr.value * 0.3"
            },
            {
              "set_var": "tp1",
              "expr": "ind.h1_nwe.yhat"
            },
            {
              "set_var": "tp2",
              "expr": "_price - ((ind.h4_smc.strong_high + ind.h4_atr.value * 0.3) - _price) * 2.0"
            },
            {
              "set_var": "risk_r",
              "expr": "(ind.h4_smc.strong_high + ind.h4_atr.value * 0.3) - _price"
            },
            {
              "open_trade": {
                "direction": "SELL",
                "sl": {
                  "expr": "ind.h4_smc.strong_high + ind.h4_atr.value * 0.3"
                },
                "tp": {
                  "expr": "ind.h1_nwe.yhat"
                }
              }
            },
            {
              "log": "Short entry: Stochastic K<D cross from overbought"
            }
          ]
        }
      ],
      "timeout": {
        "bars": 8,
        "timeframe": "M15",
        "to": "idle"
      },
      "position_management": []
    },
    "in_position": {
      "description": "Manage open trade \u00e2\u20ac\u201d breakeven at 1R, partial close 50% at TP1, trail to TP2.",
      "evaluate_on": [
        "M15"
      ],
      "transitions": [
        {
          "to": "idle",
          "priority": 0,
          "conditions": {
            "type": "AND",
            "rules": [
              {
                "left": "var.partial_closed",
                "operator": "==",
                "right": "true",
                "description": "Partial close already taken"
              },
              {
                "left": "var.be_moved",
                "operator": "==",
                "right": "true",
                "description": "Breakeven already moved"
              }
            ]
          },
          "actions": [
            {
              "log": "Trade fully managed \u00e2\u20ac\u201d waiting for SL/TP exit"
            }
          ]
        }
      ],
      "timeout": null,
      "on_trade_closed": {
        "to": "idle"
      },
      "position_management": [
        {
          "name": "breakeven_at_1r",
          "once": true,
          "continuous": false,
          "when": {
            "type": "OR",
            "rules": [
              {
                "left": "_price",
                "operator": ">=",
                "right": "var.entry_price + var.risk_r",
                "description": "Long: price reached 1R profit"
              },
              {
                "left": "_price",
                "operator": "<=",
                "right": "var.entry_price - var.risk_r",
                "description": "Short: price reached 1R profit"
              }
            ]
          },
          "modify_sl": {
            "expr": "var.entry_price"
          }
        },
        {
          "name": "partial_close_at_tp1",
          "once": true,
          "continuous": false,
          "when": {
            "type": "OR",
            "rules": [
              {
                "left": "_price",
                "operator": ">=",
                "right": "var.tp1",
                "description": "Long: price reached TP1 (NWE kernel line)"
              },
              {
                "left": "_price",
                "operator": "<=",
                "right": "var.tp1",
                "description": "Short: price reached TP1 (NWE kernel line)"
              }
            ]
          },
          "partial_close": {
            "pct": 50.0
          }
        },
        {
          "name": "trail_to_tp2",
          "once": false,
          "continuous": true,
          "when": {
            "type": "AND",
            "rules": [
              {
                "left": "var.partial_closed",
                "operator": "==",
                "right": "true",
                "description": "Only trail after partial close"
              }
            ]
          },
          "trail_sl": {
            "distance": {
              "expr": "ind.h4_atr.value * 1.0"
            },
            "step": {
              "expr": "ind.h4_atr.value * 0.3"
            }
          }
        }
      ]
    }
  },
  "risk": {
    "max_lot": 0.1,
    "max_daily_trades": 3,
    "max_drawdown_pct": 2.5,
    "max_open_positions": 1,
    "circuit_breaker": {
      "max_consecutive_losses": 3,
      "max_errors": 5,
      "cooldown_minutes": 120
    }
  }
}